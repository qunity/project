{
  "name": "qunity/project",
  "description": "Qunity Project",
  "type": "project",
  "version": "1.0.0",
  "time": "2021-04-10",
  "license": "MIT",
  "authors": [
    {
      "name": "Rodion Kachkin",
      "email": "kyleRQWS@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "qunity/framework": "*"
  },
  "autoload": {
    "psr-4": {
      "": [
        "app/code",
        "app/generated"
      ]
    },
    "files": [
      "app/functions.php",
      "app/registration.php"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.6",
    "phpmd/phpmd": "^2.10",
    "phpstan/phpstan": "^0.12"
  },
  "autoload-dev": {
    "psr-4": {
      "": [
        "dev/tests/unit"
      ]
    },
    "files": [
      "dev/functions.php"
    ]
  },
  "repositories": [
    {
      "type": "path",
      "url": "dev/code/*/*",
      "canonical": false
    }
  ]
}
